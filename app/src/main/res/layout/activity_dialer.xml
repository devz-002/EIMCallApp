<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:id="@+id/tv_dialed_number"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:gravity="center"
        android:hint="Enter number"
        android:textColor="@color/text_primary"
        android:textSize="32sp"
        android:textStyle="bold" />

    <!-- Row 1: 1 2 3 -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal">
        <Button android:id="@+id/btn1" style="@style/DialButton" android:text="1" android:layout_weight="1" android:layout_width="0dp" android:layout_height="64dp"/>
        <Button android:id="@+id/btn2" style="@style/DialButton" android:text="2" android:layout_weight="1" android:layout_width="0dp" android:layout_height="64dp"/>
        <Button android:id="@+id/btn3" style="@style/DialButton" android:text="3" android:layout_weight="1" android:layout_width="0dp" android:layout_height="64dp"/>
    </LinearLayout>

    <!-- Row 2: 4 5 6 -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal">
        <Button android:id="@+id/btn4" style="@style/DialButton" android:text="4" android:layout_weight="1" android:layout_width="0dp" android:layout_height="64dp"/>
        <Button android:id="@+id/btn5" style="@style/DialButton" android:text="5" android:layout_weight="1" android:layout_width="0dp" android:layout_height="64dp"/>
        <Button android:id="@+id/btn6" style="@style/DialButton" android:text="6" android:layout_weight="1" android:layout_width="0dp" android:layout_height="64dp"/>
    </LinearLayout>

    <!-- Row 3: 7 8 9 -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal">
        <Button android:id="@+id/btn7" style="@style/DialButton" android:text="7" android:layout_weight="1" android:layout_width="0dp" android:layout_height="64dp"/>
        <Button android:id="@+id/btn8" style="@style/DialButton" android:text="8" android:layout_weight="1" android:layout_width="0dp" android:layout_height="64dp"/>
        <Button android:id="@+id/btn9" style="@style/DialButton" android:text="9" android:layout_weight="1" android:layout_width="0dp" android:layout_height="64dp"/>
    </LinearLayout>

    <!-- Row 4: * 0 # -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal">
        <Button android:id="@+id/btn_star" style="@style/DialButton" android:text="*" android:layout_weight="1" android:layout_width="0dp" android:layout_height="64dp"/>
        <Button android:id="@+id/btn0" style="@style/DialButton" android:text="0" android:layout_weight="1" android:layout_width="0dp" android:layout_height="64dp"/>
        <Button android:id="@+id/btn_hash" style="@style/DialButton" android:text="#" android:layout_weight="1" android:layout_width="0dp" android:layout_height="64dp"/>
    </LinearLayout>

    <!-- Action row: Backspace + Call -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="16dp">
        <Button
            android:id="@+id/btn_backspace"
            android:layout_width="0dp"
            android:layout_height="64dp"
            android:layout_weight="1"
            android:text="⌫"
            android:textSize="22sp"
            android:backgroundTint="@color/background" />
        <Button
            android:id="@+id/btn_call"
            android:layout_width="0dp"
            android:layout_height="64dp"
            android:layout_weight="2"
            android:text="📞 CALL"
            android:textColor="@color/on_primary"
            android:backgroundTint="@color/incoming_call"
            android:textStyle="bold" />
    </LinearLayout>

</LinearLayout>
